{
  "version": 2,
  "builds": [
    { "src": "index.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "index.js" }
  ],
  "crons": [
    { "path": "/api/cron/sunday-summary", "schedule": "0 4 * * *" },
    { "path": "/api/cron/meetup-reminders", "schedule": "0 6 * * *" },
    { "path": "/api/cron/coach-profiles", "schedule": "0 2 * * *" }
  ]
}
