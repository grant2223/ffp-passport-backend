{
  "version": 2,
  "builds": [{ "src": "api/*.js", "use": "@vercel/node" }],
  "routes": [
    { "src": "/api/auth/signup",  "dest": "/api/auth.js" },
    { "src": "/api/auth/signin",  "dest": "/api/auth.js" },
    { "src": "/api/auth/reset",   "dest": "/api/auth.js" },
    { "src": "/api/calorie/save", "dest": "/api/calorie.js" },
    { "src": "/api/visits/log",   "dest": "/api/visits.js" }
  ]
}
